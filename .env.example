# Application Settings
APP_ENV=production
APP_NAME=Blue Ridge Farmers Collective
APP_FROM=noreply@blueridgefarmers.com

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=blue_ridge_farmers_collective

# Email Configuration
MAIL_FROM_NAME=Blue Ridge Farmers Collective
MAIL_FROM_ADDRESS=noreply@blueridgefarmers.com
MAIL_HOST=smtp.bluehost.com
MAIL_PORT=465
MAIL_USERNAME=noreply@blueridgefarmers.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl

# Application URLs
APP_URL=https://blueridgefarmers.com

# Weather Integration (OpenWeatherMap)
# Sign up for free API key at: https://openweathermap.org/api
# Free tier includes current weather and 5-day forecast
OPENWEATHER_API_KEY=your_api_key_here
WEATHER_CACHE_HOURS=6

